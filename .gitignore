# ==============================================================
# SAVING BANKING MICROSERVICES — .gitignore
# ==============================================================

# ── Environment / Secrets ──────────────────────────────────────
.env
*.env
!.env.example

# ── Java / Maven ───────────────────────────────────────────────
target/
*.class
*.jar
*.war
*.ear
*.nar
hs_err_pid*
replay_pid*
.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

# Maven wrapper (keep the script, ignore the jar)
.mvn/

# ── Python ─────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
.venv/
venv/
env/
ENV/
pip-log.txt
pip-delete-this-directory.txt
*.egg-info/
.eggs/
dist/
build/
*.egg
.mypy_cache/
.ruff_cache/
.pytest_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover

# ── Node.js ────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*
dist/
.next/
.nuxt/
.cache/
.parcel-cache/
*.tsbuildinfo

# ── IDEs & Editors ─────────────────────────────────────────────
.idea/
*.iml
*.iws
*.ipr
.eclipse/
.settings/
.classpath
.project
*.launch
.factorypath

.vscode/
*.code-workspace
.history/

*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Docker ─────────────────────────────────────────────────────
# (docker-compose.override.yml is local only)
docker-compose.override.yml
docker-compose.local.yml

# ── Logs ───────────────────────────────────────────────────────
logs/
*.log
*.log.*

# ── OS ─────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
