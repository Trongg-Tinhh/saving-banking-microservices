# ==============================================================
# SAVING BANKING MICROSERVICES - ENVIRONMENT VARIABLES
# ==============================================================
# Copy this file to .env and fill in actual values
# cp .env.example .env
# ==============================================================

# ---- PostgreSQL ----
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=saving_banking
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ---- RabbitMQ ----
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
# Management UI: http://localhost:15672 (guest/guest)

# ---- JWT ----
# MUST be at least 256 bits (32+ chars) for HS256
JWT_SECRET=s4v1ng-b4nk1ng-jwt-s3cr3t-k3y-must-be-256-bits-long!!
JWT_EXPIRATION_MS=3600000        # 1 hour
JWT_REFRESH_EXPIRATION_MS=86400000  # 24 hours

# ---- Service URLs (local dev) ----
AUTH_SERVICE_URL=http://localhost:8081
CUSTOMER_SERVICE_URL=http://localhost:8082
ACCOUNT_SERVICE_URL=http://localhost:8083
SAVING_PRODUCT_SERVICE_URL=http://localhost:8084
SAVING_CONTRACT_SERVICE_URL=http://localhost:8085
TRANSACTION_SERVICE_URL=http://localhost:8086
INTEREST_SERVICE_URL=http://localhost:8087
LIFECYCLE_SERVICE_URL=http://localhost:8088
NOTIFICATION_SERVICE_URL=http://localhost:8089
CORE_BANKING_MOCK_URL=http://localhost:8099

# ---- Service Ports ----
API_GATEWAY_PORT=3000
AUTH_SERVICE_PORT=8081
CUSTOMER_SERVICE_PORT=8082
ACCOUNT_SERVICE_PORT=8083
SAVING_PRODUCT_SERVICE_PORT=8084
SAVING_CONTRACT_SERVICE_PORT=8085
TRANSACTION_SERVICE_PORT=8086
INTEREST_SERVICE_PORT=8087
LIFECYCLE_SERVICE_PORT=8088
NOTIFICATION_SERVICE_PORT=8089
CORE_BANKING_MOCK_PORT=8099

# ---- API Gateway ----
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# ---- Default Test Credentials ----
# admin / Admin@123
# teller01 / Teller@123
# customer001 / Test@123
# customer002 / Test@123
