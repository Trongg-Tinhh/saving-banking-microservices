# ─── Server ────────────────────────────────────────────────────────────────
PORT=3000

# ─── JWT ───────────────────────────────────────────────────────────────────
# Phải khớp với JWT_SECRET trong auth-service
# Tối thiểu 256-bit cho HS256 — thay bằng secret thật ở production
JWT_SECRET=your-super-secret-jwt-key-must-be-at-least-256-bits-long-for-hs256

# ─── Upstream Services ─────────────────────────────────────────────────────
# Local development → dùng localhost
# Docker Compose    → dùng tên service (vd: http://auth-service:8081)
AUTH_SERVICE_URL=http://localhost:8081
CUSTOMER_SERVICE_URL=http://localhost:8082
ACCOUNT_SERVICE_URL=http://localhost:8083
PRODUCT_SERVICE_URL=http://localhost:8084
CONTRACT_SERVICE_URL=http://localhost:8085
TRANSACTION_SERVICE_URL=http://localhost:8086
INTEREST_SERVICE_URL=http://localhost:8087
LIFECYCLE_SERVICE_URL=http://localhost:8088
NOTIFICATION_SERVICE_URL=http://localhost:8089

# ─── CORS ──────────────────────────────────────────────────────────────────
# Danh sách origin cho phép, phân cách bằng dấu phẩy (không có khoảng trắng)
# Để trống hoặc xóa biến này để cho phép tất cả origins (chỉ dùng ở dev)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Rate Limiting ─────────────────────────────────────────────────────────
RATE_LIMIT_TTL=60000    # Thời gian cửa sổ tính bằng millisecond (mặc định: 60s)
RATE_LIMIT_MAX=100      # Số request tối đa trong mỗi cửa sổ
